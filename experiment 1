def print_board(board):
    for row in board:
        print(" ".join("Q" if col else "." for col in row))
    print()

def is_safe(board, row, col):
    # Check row on left side
    for i in range(col):
        if board[row][i]:
            return False

    # Upper diagonal
    i, j = row - 1, col - 1
    while i >= 0 and j >= 0:
        if board[i][j]:
            return False
        i -= 1
        j -= 1

    # Lower diagonal
    i, j = row + 1, col - 1
    while i < N and j >= 0:
        if board[i][j]:
            return False
        i += 1
        j -= 1

    return True

def solve_n_queens(board, col):
    if col >= N:
        return True

    for i in range(N):
        if is_safe(board, i, col):
            board[i][col] = 1

            if solve_n_queens(board, col + 1):
                return True

            board[i][col] = 0

    return False

def main():
    board = [[0]*N for _ in range(N)]

    if solve_n_queens(board, 0):
        print("Solution to 8-Queens Problem:\n")
        print_board(board)
    else:
        print("No solution exists")

main()

